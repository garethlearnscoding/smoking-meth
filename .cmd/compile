#!/usr/bin/env bash
set -euo pipefail

chapter=""
file=""
copy=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -c|--chapter) chapter="$2"; shift 2 ;;
        -f|--filename) file="$2"; shift 2 ;;
        --copy) copy=true; shift ;;
        *) echo "Usage: build [-c <chapter>] [-f <filename>] [--copy]"; exit 1 ;;
    esac
done

repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
cd "$repo_root"

if [[ -z "$chapter" ]]; then
    chapter=$(find tex -mindepth 1 -maxdepth 1 -type d -not -name "build" | sed 's|tex/||' \
        | fzf --prompt='  ' \
              --border-label=' chapter ' \
              --color=bg:-1 \
              --height=~40%) || { echo "No chapter selected."; exit 1; }
fi

if [[ -z "$file" ]]; then
    file=$(find "tex/$chapter" -maxdepth 1 -name "*.tex" -not -path "*/build/*" | sed "s|tex/$chapter/||; s|\.tex$||" \
        | fzf --prompt='  ' \
              --border-label=' file ' \
              --color=bg:-1 \
              --height=~40%) || { echo "No file selected."; exit 1; }
fi

tex_path="tex/$chapter/$file.tex"

[[ -f "$tex_path" ]] || { echo "Error: $tex_path not found"; exit 1; }

workdir="$(dirname "$tex_path")"
base="$(basename "$file")"

cd "$workdir"

info()    { echo "[build] $*"; }
section() { echo "" && echo "[build] --- $* ---"; }

section "latexmk: $tex_path"
latexmk -pdf -silent \
    -usepretex -pretex="\def\exportmode{1}" \
    "${base}.tex" > /dev/null 2>&1 && info "converted to pdf" || {
    echo "[build] failed"
    exit 1
}

info "cleaning aux files"
rm -f *.aux *.log *.fls *.fdb_latexmk *.synctex.gz *.out *.toc *.bbl *.blg || true

svg_dir="$repo_root/tex/$chapter/svg"
mkdir -p "$svg_dir"

section "inkscape: $base.svg"
inkscape "$base.pdf" \
    --export-type=svg \
    --export-filename="$svg_dir/$base.svg" \
    --export-background-opacity=0 > /dev/null 2>&1 && info "converted to svg" || {
    echo "[build] failed"
    exit 1
}
rm -f "$base.pdf"

section "output"
info "tex/$chapter/svg/$base.svg"

# --- Copy ---
if [[ "$copy" == false ]]; then
    printf "\n[build] copy svg to assets? [y/N] "
    read -r answer
    [[ "$answer" =~ ^[Yy]$ ]] && copy=true
fi

if [[ "$copy" == true ]]; then
    section "copy"
    assets_dir="$repo_root/assets/graphs"

    if [[ -d "$assets_dir/$chapter" ]]; then
        dest="$assets_dir/$chapter"
        info "found assets/$chapter"
    else
        info "assets/$chapter not found, select destination:"
        dest=$(
            { echo "+ create assets/$chapter"; find "$assets_dir" -mindepth 1 -maxdepth 1 -type d | sed "s|$assets_dir/||"; } \
            | fzf --prompt='  ' \
                --border-label=' assets folder ' \
                --color=bg:-1 \
                --height=~40%) || { echo "No folder selected."; exit 1; }

        if [[ "$dest" == "+ create assets/$chapter" ]]; then
            mkdir -p "$assets_dir/$chapter"
            dest="$assets_dir/$chapter"
            info "created assets/$chapter"
        else
            dest="$assets_dir/$dest"
        fi
    fi

    cp "$svg_dir/$base.svg" "$dest/$base.svg"
    info "copied to ${dest#$repo_root/}/$base.svg"
fi