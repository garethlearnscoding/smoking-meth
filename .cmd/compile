#!/usr/bin/env bash
set -euo pipefail

chapter=""
file=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -c|--chapter)
            chapter="$2"
            shift 2
            ;;
        -f|--filename)
            file="$2"
            shift 2
            ;;
        *)
            echo "Usage: build -c <chapter> -f <filename>"
            exit 1
            ;;
    esac
done

if [[ -z "$chapter" || -z "$file" ]]; then
    echo "Usage: build -c <chapter> -f <filename>"
    exit 1
fi

repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)

cd "$repo_root"

tex_path="tex/$chapter/$file.tex"

if [[ ! -f "$tex_path" ]]; then
    echo "Error: $tex_path not found"
    exit 1
fi

workdir="$(dirname "$tex_path")"
base="$(basename "$file")"

cd "$workdir"

echo "Building in: $workdir"

latexmk -pdf "$base.tex"

rm -f *.aux *.log *.fls *.fdb_latexmk *.synctex.gz *.out *.toc *.bbl *.blg || true

pdf="$base.pdf"
svg="$base.svg"

[[ -f "$pdf" ]] || { echo "PDF missing"; exit 1; }

inkscape "$pdf" \
  --export-type=svg \
  --export-filename="$svg" \
  --export-background-opacity=0

echo "Done: $pdf + $svg"